# Copy this file to `.env` and fill in your real secrets.
# These stay server-side ONLY — never ship them to the browser.

# Google Gemini (Generative Language API) key used by the triage agent
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB Atlas connection string for cluster "resqnet-cluster"
# e.g. mongodb+srv://user:pass@resqnet-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=your-mongodb-atlas-uri

# Arize / Phoenix observability
ARIZE_API_KEY=your-arize-key
# Trace ingest endpoint (Phoenix Cloud default shown). Leave blank to disable export.
ARIZE_TRACE_URL=https://app.phoenix.arize.com/v1/traces

# HTTP port for this backend
PORT=8787

# Comma-separated list of allowed browser origins for CORS.
# Use * for local dev; lock this down in production.
ALLOWED_ORIGINS=*
