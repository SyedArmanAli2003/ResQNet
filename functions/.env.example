# Copy to functions/.env for local emulator use.
# For deployed functions, set secrets via Firebase CLI:
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set MONGODB_URI
#   firebase functions:secrets:set ARIZE_API_KEY

GEMINI_API_KEY=your-gemini-api-key-here
MONGODB_URI=your-mongodb-atlas-uri

# Arize Phoenix observability (OTLP/HTTP trace export)
ARIZE_API_KEY=your-arize-key
# Optional — override the OTLP ingest endpoint / set your Arize space id
ARIZE_OTLP_URL=https://otlp.arize.com/v1/traces
ARIZE_SPACE_ID=
